{
    "name": "ez-php/rate-limiter",
    "version": "1.0.1",
    "description": "Rate limiter module for the ez-php framework \u2014 array, Redis, and cache-backed drivers with ThrottleMiddleware",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "rate-limiter",
        "throttle",
        "redis",
        "php",
        "framework",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/rate-limiter",
    "support": {
        "issues": "https://github.com/ez-php/rate-limiter/issues",
        "source": "https://github.com/ez-php/rate-limiter"
    },
    "require": {
        "php": "^8.5",
        "ez-php/contracts": "^1.0",
        "ez-php/http": "^1.0",
        "ez-php/cache": "^1.0"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "ez-php/testing-application": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\RateLimiter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
